{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix . --quiet",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "npx astro check",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
