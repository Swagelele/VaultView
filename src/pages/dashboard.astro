---
export const prerender = false;
import Layout from "@/layouts/Layout.astro";
import { AddTransactionButton } from "@/components/portfolio/AddTransactionButton";
---

<Layout title="Portfolio — VaultView">
  <div class="min-h-screen bg-neutral-950 p-6 text-white">
    <div class="mx-auto max-w-5xl">
      <div class="mb-8 flex items-center justify-between">
        <h1 class="text-2xl font-bold">Portfolio</h1>
        <div class="flex items-center gap-4">
          <AddTransactionButton client:load />
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
            >
              Sign out
            </button>
          </form>
        </div>
      </div>
      <p class="text-muted-foreground">Portfolio view coming soon — add your first transaction above.</p>
    </div>
  </div>
</Layout>
