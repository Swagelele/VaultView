---
export const prerender = false;
import Layout from "@/layouts/Layout.astro";
import { TransactionList } from "@/components/portfolio/TransactionList";
---

<Layout title="Transactions — VaultView">
  <div class="min-h-screen bg-neutral-950 p-6 text-white">
    <div class="mx-auto max-w-5xl">
      <div class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-bold">Transactions</h1>
        <a
          href="/dashboard"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          ← Portfolio
        </a>
      </div>
      <TransactionList client:load />
    </div>
  </div>
</Layout>
